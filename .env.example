# Copy this file to .env.local for local development.
# Do not commit .env.local; it may contain API keys and cookies.

# AI provider selection.
AI_DEFAULT_PROVIDER=relay

# Relay provider. Used by default for /api/analysis/stream.
AI_RELAY_NAME=AI relay
AI_RELAY_BASE_URL=https://relay.nf.video/v1
AI_RELAY_MODEL=gpt-5.5
AI_RELAY_WIRE_API=responses
AI_RELAY_REASONING_EFFORT=high
AI_RELAY_DISABLE_RESPONSE_STORAGE=true
AI_RELAY_API_KEY=sk-ant-sid01--8352ecf3354e00ef8a1dd88e6346f18b5df79ffedbe263f12361b8ae6b755643

# Optional OpenAI-compatible providers.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Optional Fenbi cookie. You can also set it from /admin.html locally.
FENBI_COOKIE=""

# Local server origin allowlist. Keep this in sync if you change the port.
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
